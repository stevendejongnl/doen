# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./doen.db
DB_MODE=sqlite
SECRET_KEY=dev-secret-change-in-production
DEBUG=true

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL users see in the browser. Used to build links in outgoing emails.
APP_BASE_URL=http://localhost:5173

# ── Home Assistant OAuth ──────────────────────────────────────────────────────
HA_BASE_URL=http://192.168.1.141:8123
HA_CLIENT_ID=http://localhost:5173/

# ── Mail (SMTP relay) ─────────────────────────────────────────────────────────
# Disable in dev/tests — service will log mails instead of sending.
MAIL_ENABLED=false

# Prod example: mailcow at mail.steven-dejong.nl
# SMTP_HOST=mail.steven-dejong.nl
# SMTP_PORT=587
# SMTP_USER=noreply@steven-dejong.nl
# SMTP_PASSWORD=change-me
# SMTP_FROM=noreply@steven-dejong.nl
# SMTP_FROM_NAME=Doen
# SMTP_USE_STARTTLS=true      # port 587 submission
# SMTP_USE_TLS=false          # set true (and port 465) for implicit SMTPS
